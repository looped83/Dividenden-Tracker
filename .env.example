# Supabase-Projektzugang (SECURITY_MODEL.md §5).
# VITE_SUPABASE_ANON_KEY ist der oeffentliche Anon/Publishable Key, kein
# Geheimnis (durch Row Level Security geschuetzt). Der Service-Role-Key
# gehoert NIEMALS in diese Datei, das Frontend oder das Repository.
VITE_SUPABASE_URL=https://<projekt>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>
