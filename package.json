{
  "name": "dividend-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:test:reset": "bash scripts/db/reset-test-db.sh",
    "test:integration": "npm run db:test:reset && vitest run --config vitest.integration.config.ts",
    "gen:types": "supabase gen types typescript --db-url \"postgresql://postgres:postgres@127.0.0.1:5432/dividend_tracker_test\" --schema public > src/lib/supabase/database.types.ts"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.2.0",
    "@tanstack/react-query": "5.101.2",
    "react-hook-form": "7.82.0",
    "@hookform/resolvers": "5.4.0",
    "zod": "4.4.3",
    "decimal.js": "10.6.0",
    "recharts": "3.9.2",
    "clsx": "2.1.1",
    "tailwind-merge": "3.6.0",
    "class-variance-authority": "0.7.1",
    "lucide-react": "1.25.0",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-label": "2.1.11",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-dropdown-menu": "2.1.20",
    "@radix-ui/react-tabs": "1.1.17",
    "@radix-ui/react-tooltip": "1.2.12",
    "@supabase/supabase-js": "2.110.7"
  },
  "devDependencies": {
    "vite": "8.1.5",
    "@vitejs/plugin-react": "6.0.3",
    "@tailwindcss/vite": "4.3.3",
    "tailwindcss": "4.3.3",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "eslint": "10.7.0",
    "@eslint/js": "10.0.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "pg": "8.22.0",
    "vitest": "4.1.10",
    "@vitest/ui": "4.1.10",
    "@testing-library/react": "16.3.2",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/user-event": "14.5.2",
    "jsdom": "29.1.1",
    "prettier": "3.9.5"
  }
}
